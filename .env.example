# Gemini – em produção fica só no servidor (Vercel: GEMINI_API_KEY). Local: .env para npm run dev
GEMINI_API_KEY=sua_chave_gemini

# Supabase – copie para .env e preencha em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key
